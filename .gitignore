# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# claude code worktrees + agent state
/.claude/

# design handoff bundle uploads (large source PDFs — keep out of git)
docs/handoff/uploads/

# extracted catalogue page renders — regenerate from docs/handoff/uploads/catalog.pdf
docs/catalog-extract/

# internal-only drafts and planning docs (lives in ~/Dev/linetech/company-docs-private/)
docs/internal/

# typescript
*.tsbuildinfo
next-env.d.ts

# generated search index (rebuilt by prebuild/predev)
public/search/

# sanity typegen intermediate artifact (regenerated by pnpm sanity:extract)
/schema.json

# sanity typegen output (regenerated by pnpm sanity:typegen)
/sanity.types.ts

# Playwright
/playwright-report/
/test-results/
