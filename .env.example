NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SITE_URL=https://linetech.co.kr

# Resend — resend.com → API Keys → Create Key
RESEND_API_KEY=
# Optional: custom "from" address once your domain is verified in Resend.
# Defaults to onboarding@resend.dev (Resend shared domain) if unset.
RESEND_FROM=

# Cloudflare Turnstile — cloudflare.com → Turnstile → Add site
# Without these the submit button stays disabled.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
